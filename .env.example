# 浙里Trip 环境变量配置模板
# 复制此文件为 .env 并填入你的API Key
# cp .env.example .env

# ==================== 应用配置 ====================
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=dev  # dev | production

# ==================== LLM配置 ====================
# LLM提供商: auto | deepseek | bigmodel
# auto: 优先使用智谱，失败降级到DeepSeek
LLM_PROVIDER=auto

# DeepSeek配置
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_MODEL=deepseek-v4-flash

# 智谱AI配置
BIGMODEL_API_KEY=xxx
BIGMODEL_MODEL=glm-4.5-air

# ==================== 高德地图配置 ====================
# JS SDK Key（用于前端，配置在 h5/index.html 中）
# AMAP_JS_KEY=5f4bdb7d72c8683bfc46430bd84db3df

# Web服务Key（用于后端API调用，地理编码/路线规划等）
AMAP_API_KEY=你的高德Web服务Key

# ==================== 数据库配置（未来使用） ====================
# DATABASE_URL=postgresql://user:password@localhost:5432/zheilitrip
# REDIS_URL=redis://localhost:6379/0

# ==================== 其他配置 ====================
# 日志级别: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# CORS允许的来源（生产环境配置你的域名）
# CORS_ORIGINS=https://your-domain.com
